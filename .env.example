# Copy to `.env.local` and adjust.

# Backend origin (no trailing path) — used by Next.js rewrites in next.config.mjs
BACKEND_URL=http://127.0.0.1:5000

# Optional: call the API directly from the browser (bypasses Next rewrites). Use this if long
# requests (e.g. tenant DB provisioning) time out — CORS must allow your frontend origin on the backend.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:5000/api/v1
