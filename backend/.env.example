# Copy to .env and fill in values.

PORT=5000
NODE_ENV=development

MAIN_DB_HOST=localhost
MAIN_DB_PORT=5432
MAIN_DB_NAME=finx_main_db
MAIN_DB_USER=postgres
MAIN_DB_PASS=

TENANT_DB_HOST=localhost
TENANT_DB_PORT=5432
TENANT_DB_USER=postgres
TENANT_DB_PASS=

JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me_refresh

# SMTP — required for billing invoice emails, welcome emails, support notifications
# Quote SMTP_PASS and SMTP_FROM if they contain special characters.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS="your-smtp-password"
SMTP_FROM="FinX <notifications@example.com>"

# Optional TLS tuning (see src/services/notificationService.js)
# SMTP_TLS_REJECT_UNAUTHORIZED=false
# SMTP_REQUIRE_TLS=false

CORS_ORIGIN=http://localhost:3000
