# ── Backend (where Node/Express listens; used by next.config.mjs rewrites) ──
BACKEND_URL=http://127.0.0.1:5000

# Optional: force full API URL in the browser (skips proxy). Example:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:5000/api/v1
#
# Default: leave NEXT_PUBLIC_API_URL unset so the app uses same-origin /api/v1
# (proxied to BACKEND_URL — fixes ERR_NETWORK / env not loading in the client).
